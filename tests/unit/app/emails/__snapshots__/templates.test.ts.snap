            0 2px 4px -1px rgba(0, 0, 0, 0.06);"><tbody><tr style="width: 100%"><td><!-- Top Gradient Accent --><table align="center" width="100%" data-id="__vue-email-section" border="0" cellpadding="0" cellspacing="0" role="presentation" style="background:linear-gradient(135deg, #00dc82 0%, #00c16a 100%);height:4px;width:100%;"><tbody><tr><td></td></tr></tbody></table><!-- Header --><table align="center" width="100%" data-id="__vue-email-section" border="0" cellpadding="0" cellspacing="0" role="presentation" style="padding:32px 40px 0;text-align:center;"><tbody><tr><td><a data-id="__vue-email-link" style="color: #067df7; text-decoration: none" href="https://coachwatts.com" target="_blank"><img data-id="__vue-email-img" style="display:block;outline:none;border:none;text-decoration:none;margin:0 auto;border-radius:12px;" src="https://coachwatts.com/icon.png" width="64" height="64" alt="Coach Watts"></a></td></tr></tbody></table><!-- Main Content (Slot) --><table align="center" width="100%" data-id="__vue-email-section" border="0" cellpadding="0" cellspacing="0" role="presentation" style="padding:32px 40px;"><tbody><tr><td><!-- Dynamic Header Graphic --><svg width="100%" height="40" viewBox="0 0 600 40" preserveAspectRatio="none" style="display:block;margin-bottom:24px;"><defs><linearGradient id="brandGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#00dc82" stop-opacity="0.1"></stop><stop offset="100%" stop-color="#00c16a" stop-opacity="0.9"></stop></linearGradient></defs><path d="M0,40 L600,40 L600,0 L100,0 L0,30 Z" fill="url(#brandGrad)"></path><polygon points="580,10 590,10 600,0 590,0" fill="#00dc82"></polygon><polygon points="560,15 575,15 590,0 575,0" fill="#00c16a" opacity="0.6"></polygon></svg><h1 data-id="__vue-email-heading" style="font-size:24px;line-height:1.3;font-weight:700;color:#09090b;margin-top:0;margin-bottom:20px;letter-spacing:-0.025em;">Workout synced and momentum building.</h1><p data-id="__vue-email-text" style="font-size:16px;line-height:1.6;margin:16px 0;color:#71717a;margin-bottom:24px;"> Hi Alex Athlete, </p><!-- Unified Coach Synthesis --><table align="center" width="100%" data-id="__vue-email-container" role="presentation" cellspacing="0" cellpadding="0" border="0" style="max-width:37.5em;background-color:#fafafa;border-radius:12px;padding:24px;margin-bottom:24px;border-left:4px solid #00dc82;border-top:1px solid #e4e4e7;border-right:1px solid #e4e4e7;border-bottom:1px solid #e4e4e7;"><tbody><tr style="width: 100%"><td><p data-id="__vue-email-text" style="font-size:10px;line-height:24px;margin:0 0 12px;font-weight:900;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.2em;"> Coach&#39;s Synthesis </p><p data-id="__vue-email-text" style="font-size:15px;line-height:1.7;margin:0 0 12px;color:#27272a;">Solid work today. Progression Run is now on your timeline and ready to review. <span>This load is in a productive range and supports fitness gains without excessive strain.</span><span>Average HR was about 91% of LTHR, a steady effort that builds durable race fitness.</span><span> Efficiency signal: you produced strong power while keeping heart rate controlled.</span></p><p data-id="__vue-email-text" style="font-size:15px;line-height:1.7;margin:0;color:#27272a;">You are training above your recent baseline in a productive range that supports progression. <span style="color:#059669;font-weight:500;">That is 3 sessions in the last 7 days. Strong consistency momentum.</span></p></td></tr></tbody></table><!-- Key Metrics Grid --><table align="center" width="100%" data-id="__vue-email-container" role="presentation" cellspacing="0" cellpadding="0" border="0" style="max-width:37.5em;background-color:#ffffff;border-radius:12px;padding:20px;margin-bottom:24px;border:1px solid #e4e4e7;"><tbody><tr style="width: 100%"><td><table align="center" width="100%" data-id="__vue-email-row" role="presentation" cellspacing="0" cellpadding="0" border="0"><tbody style="width: 100%"><tr style="width: 1