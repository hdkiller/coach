ttom:14px;border:1px solid #e4e4e7;"><tbody><tr style="width: 100%"><td><p data-id="__vue-email-text" style="font-size:10px;line-height:24px;margin:0 0 8px;font-weight:900;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.2em;">Current Execution Score</p><p data-id="__vue-email-text" style="font-size:48px;line-height:1;margin:0;font-weight:700;color:#09090b;font-variant-numeric:tabular-nums;">8<span style="font-size:24px;color:#a1a1aa;">/10</span></p></td></tr></tbody></table><table align="center" width="100%" data-id="__vue-email-container" role="presentation" cellspacing="0" cellpadding="0" border="0" style="max-width:37.5em;background-color:#fafafa;border-radius:12px;padding:18px;margin-bottom:14px;border:1px solid #e4e4e7;"><tbody><tr style="width: 100%"><td><p data-id="__vue-email-text" style="font-size:10px;line-height:24px;margin:0 0 8px;font-weight:900;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.2em;">Key Insight</p><p data-id="__vue-email-text" style="font-size:15px;line-height:1.6;margin:0;color:#52525b;">Solid pacing with one late fade.</p></td></tr></tbody></table><table align="center" width="100%" data-id="__vue-email-container" role="presentation" cellspacing="0" cellpadding="0" border="0" style="max-width:37.5em;background-color:#fafafa;border-radius:12px;padding:18px;margin-bottom:14px;border:1px solid #e4e4e7;"><tbody><tr style="width: 100%"><td><p data-id="__vue-email-text" style="font-size:10px;line-height:24px;margin:0 0 8px;font-weight:900;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.2em;">Observations</p><ul style="font-size:14px;line-height:1.6;color:#52525b;margin:0;padding-left:18px;"><li>Start first interval 10W lower</li><li>Fuel earlier in warmup</li></ul></td></tr></tbody></table><!--v-if--><table align="center" width="100%" data-id="__vue-email-container" role="presentation" cellspacing="0" cellpadding="0" border="0" style="max-width:37.5em;background-color:#fafafa;border-radius:12px;padding:18px;margin-bott