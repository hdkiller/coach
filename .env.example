## ------------------------------------------------------------------
## DATABASE
## ------------------------------------------------------------------

# Local development (direct connection to host-mapped port 5439):
DATABASE_URL="postgresql://watts:change-me-in-production@localhost:5439/watts?connection_limit=20&pool_timeout=10&connect_timeout=10"
DATABASE_URL_PROD="postgresql://watts:change-me-in-production@localhost:5439/watts"

# ------------------------------------------------------------------
# DOCKER COMPOSE — service credentials
# ------------------------------------------------------------------
# These vars drive the postgres + dragonfly services AND are used by
# docker-compose to build the DATABASE_URL / REDIS_URL injected into
# the app container (you do NOT need to set DATABASE_URL / REDIS_URL
# yourself when running the full stack via docker-compose).
# ⚠️  Change ALL of these before running in any non-local environment.
POSTGRES_USER=watts
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=watts
DRAGONFLY_PASSWORD=change-me-in-production

# PostgreSQL direct access (scripts / tools outside Docker):
POSTGRES_HOST=localhost
POSTGRES_PORT=5439
POSTGRES_DATABASE=watts

# Google oauth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Cloud Storage
# For development, you can place 'gcs-key.json' in the root (ignored by git).
# For production, set GCS_KEY_JSON with the content of the key file (JSON string).
# GCS_KEY_JSON='{"type": "service_account", ...}'
# GCLOUD_PROJECT=coach-app-481412
# GCS_BUCKET_NAME=coach-wattz-public-assets

# Gemini API KEY
GEMINI_API_KEY=your-gemini-api-key

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_your-secret-key
TRIGGER_PROJECT_REF=proj_your-project-ref
TRIGGER_API_KEY=tr_dev_your-api-key

# Nuxt Auth Config
# ⚠️  NUXT_AUTH_SECRET must be a random secret — generate with: openssl rand -hex 32
NUXT_AUTH_SECRET="your-auth-secret"
# IMPORTANT: Must match the URL where the app is reachable (no trailing slash on origin).
# The callback URL will be: {NUXT_AUTH_ORIGIN}/callback/google
# Local dev (pnpm dev):   http://localhost:3099/api/auth
# Docker (docker-compose): docker-compose sets this to http://localhost:3000/api/auth automatically
# Production:              https://your-domain.com/api/auth
NUXT_AUTH_ORIGIN="http://localhost:3099/api/auth"
NUXT_PUBLIC_SITE_URL="http://localhost:3099/"

# Local / private-instance login (no OAuth required)
# When both are set, a "Local Account" login form appears on the sign-in page.
# The user is auto-created in the DB on first login with admin rights.
# AUTH_BYPASS_NAME sets the display name (optional, defaults to "Admin").
AUTH_BYPASS_USER=""
AUTH_BYPASS_PASSWORD=""
AUTH_BYPASS_NAME=""

# Private instance mode — set to "true" to block new account creation.
# Only users already in the DB can sign in (any OAuth provider, any account whose
# email matches an existing user). Combined with AUTH_BYPASS_USER this means:
#   1. First login: use the Local Account form → creates your user in the DB
#   2. Subsequent logins: any provider works as long as the email matches
#   3. Nobody else can ever create an account
NUXT_PRIVATE_INSTANCE="false"

STRAVA_CLIENT_ID="your-strava-client-id"
STRAVA_CLIENT_SECRET="your-strava-client-secret"
STRAVA_WEBHOOK_VERIFY_TOKEN="your-strava-webhook-verify-token"
NUXT_PUBLIC_STRAVA_ENABLED=true

WHOOP_CLIENT_ID="your-whoop-client-id"
WHOOP_CLIENT_SECRET="your-whoop-client-secret"

INTERVALS_CLIENT_ID="your-intervals-client-id"
INTERVALS_CLIENT_SECRET="your-intervals-client-secret"
INTERVALS_WEBHOOK_SECRET="your-intervals-webhook-secret"

WITHINGS_CLIENT_ID=""
WITHINGS_CLIENT_SECRET=""

FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""
FITBIT_SUBSCRIBER_VERIFICATION_CODE="your-verification-code"
FITBIT_ENABLE_INTRADAY_HEART_RATE="false"
# Set to "true" to enable intraday heart-rate fetches (may increase Fitbit API usage and rate limiting)

# Redis / DragonflyDB
# Local dev: connect to host-mapped port. In Docker, REDIS_URL is auto-set
# by docker-compose using DRAGONFLY_PASSWORD above — no need to change this
# when using docker-compose up.
REDIS_URL=redis://:change-me-in-production@localhost:6379
REALTIME_DEBUG=false
# Optional comma-separated filter for realtime log channels: activity,task_run,notification,chat,bus,ws
REALTIME_DEBUG_CHANNELS=
REALTIME_DEBUG_VERBOSE=false

# Worker Configuration
CW_WORKER_QUEUE_WEBHOOK_CONCURRENCY=1

# Sentry (optional — leave SENTRY_DSN unset/empty to disable Sentry entirely for private instances)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# Postmark Email API
POSTMARK_API_KEY="your-postmark-api-key"

# Rate Limiting
WEBHOOK_RATE_LIMIT_MAX=100
WEBHOOK_RATE_LIMIT_TTL=60

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Product & Price IDs - Supporter Tier
STRIPE_SUPPORTER_PRODUCT_ID=prod_your-supporter-product-id
STRIPE_SUPPORTER_MONTHLY_PRICE_ID=price_your-supporter-monthly-usd-price-id
STRIPE_SUPPORTER_ANNUAL_PRICE_ID=price_your-supporter-annual-usd-price-id
STRIPE_SUPPORTER_MONTHLY_EUR_PRICE_ID=price_your-supporter-monthly-eur-price-id
STRIPE_SUPPORTER_ANNUAL_EUR_PRICE_ID=price_your-supporter-annual-eur-price-id

# Stripe Product & Price IDs - Pro Tier
STRIPE_PRO_PRODUCT_ID=prod_your-pro-product-id
STRIPE_PRO_MONTHLY_PRICE_ID=price_your-pro-monthly-usd-price-id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your-pro-annual-usd-price-id
STRIPE_PRO_MONTHLY_EUR_PRICE_ID=price_your-pro-monthly-eur-price-id
STRIPE_PRO_ANNUAL_EUR_PRICE_ID=price_your-pro-annual-eur-price-id

# Subscription Availability
NUXT_PUBLIC_SUBSCRIPTIONS_ENABLED=true

# Oura
OURA_CLIENT_ID=""
OURA_CLIENT_SECRET=""
OURA_WEBHOOK_VERIFICATION_TOKEN=""

# Polar
POLAR_CLIENT_ID=""
POLAR_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY="re_123456789"
SUPPORT_EMAIL="support@coachwatts.com"
MAIL_FROM_ADDRESS="Coach Watts <support@coachwatts.com>"
INTERNAL_API_TOKEN="set-a-long-random-token"
# Set to "true" to disable automatic email dispatching and keep emails in QUEUED status for manual approval
DISABLE_EMAILS="false"
EMAIL_UNSUBSCRIBE_TOKEN_TTL_SECONDS="2592000"

GARMIN_CLIENT_ID=""
GARMIN_CLIENT_SECRET=""

WAHOO_CLIENT_ID=""
WAHOO_CLIENT_SECRET=""
WAHOO_WEBHOOK_KEY=""

ULTRAHUMAN_CLIENT_ID=""
ULTRAHUMAN_CLIENT_SECRET=""

# Google Analytics / Tag Manager

NUXT_PUBLIC_GTAG_ID=""

# Tolgee (translations)
# Used by both the app (DevTools in development) and the CLI (pnpm i18n:pull / i18n:push)
TOLGEE_API_ENABLED="false"
TOLGEE_API_URL="https://app.tolgee.io"
TOLGEE_API_KEY=""
