{
  "projectId": 2,
  "push": {
    "files": [
      { "path": "app/i18n/en", "language": "en", "template": "{namespace}.json" },
      { "path": "app/i18n/hu", "language": "hu", "template": "{namespace}.json" }
    ]
  },
  "pull": {
    "path": "app/i18n",
    "fileStructureTemplate": "{languageTag}/{namespace}.json"
  }
}
